# ── Email delivery (direct SMTP via the icretools mailbox) ──────────────────
# Just the mailbox password — no Azure app registration or admin consent needed.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
BOOKING_HOST_EMAIL=icretools@icretegy.com
BOOKING_HOST_PASSWORD=the-mailbox-password-here
BOOKING_FROM_EMAIL=iPharmaAI Demos <icretools@icretegy.com>

# ── Microsoft Entra ID (Azure AD) App Registration — NOT CURRENTLY USED ─────
# Needed only for real MS Teams meetings + calendar availability checks.
# Created by admin@icretegy.on.microsoft.com (Global Admin) in Azure Portal →
# Entra ID → App Registrations, with admin-consented Application permissions:
#   Calendars.ReadWrite | OnlineMeetings.ReadWrite | Mail.Send
# Once set, swap src/app/api/book and src/app/api/availability back to
# src/lib/graph.ts for real Teams meetings + busy-slot checks.
# AZURE_TENANT_ID=your-tenant-id-here
# AZURE_CLIENT_ID=your-client-id-here
# AZURE_CLIENT_SECRET=your-client-secret-here
