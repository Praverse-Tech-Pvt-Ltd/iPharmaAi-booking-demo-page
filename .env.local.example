# ── Email delivery (Resend — free tier) ─────────────────────────────────────
# Sign up at https://resend.com (free: 100 emails/day, 3000/month).
# No domain verification needed if you keep the default onboarding@resend.dev
# sender below. Verify a domain later to send from your own address.
RESEND_API_KEY=your-resend-api-key-here
BOOKING_FROM_EMAIL=iPharmaAI Demos <onboarding@resend.dev>

# ── Booking host ─────────────────────────────────────────────────────────────
# Receives a notification email for every new booking.
BOOKING_HOST_EMAIL=icretools@icretegy.com

# ── Microsoft Entra ID (Azure AD) App Registration — NOT CURRENTLY USED ─────
# Kept for when the client's Azure admin (admin@icretegy.on.microsoft.com)
# completes app registration + admin consent. Once set, swap src/app/api/book
# and src/app/api/availability back to src/lib/graph.ts for real MS Teams
# meetings + calendar availability.
# Required permissions (Application type, admin-consented):
#   Calendars.ReadWrite | OnlineMeetings.ReadWrite | Mail.Send
# AZURE_TENANT_ID=your-tenant-id-here
# AZURE_CLIENT_ID=your-client-id-here
# AZURE_CLIENT_SECRET=your-client-secret-here
